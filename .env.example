# Copie ce fichier en ".env" en local, ou configure ces variables
# directement dans l'onglet "Variables" de ton service Railway.
# NE JAMAIS commit le fichier .env réel sur GitHub.

# ─── Discord ───────────────────────────────────────────────
# Discord Developer Portal > Bot > Reset Token
DISCORD_TOKEN=ton_token_discord_ici

# ─── Rôles ──────────────────────────────────────────────────
# IDs des rôles autorisés à utiliser "nova.getid" (consulter les cartes).
# Plusieurs rôles possibles, séparés par des virgules, sans espace.
# Exemple : VIEWER_ROLE_IDS=123456789012345678,987654321098765432
VIEWER_ROLE_IDS=id_role_1,id_role_2

# Rôle retiré automatiquement au joueur une fois sa carte créée
# (laisser vide pour désactiver ce comportement)
ROLE_TO_REMOVE_ID=id_role_a_retirer

# Rôle ajouté automatiquement au joueur une fois sa carte créée
# (laisser vide pour désactiver ce comportement)
ROLE_TO_ADD_ID=id_role_a_ajouter

# ─── Salon d'archives ───────────────────────────────────────
# ID du salon où chaque carte créée est automatiquement envoyée en copie
# (clic droit sur le salon > Copier l'ID, avec le mode développeur activé)
LOG_CHANNEL_ID=id_du_salon_logs

# ─── Réglages du bot ────────────────────────────────────────
# Nombre maximum de cartes d'identité qu'un même membre Discord peut créer
MAX_CARDS_PER_USER=2
